<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Naseny leh ya maluk ?</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;700&family=Playfair+Display:wght@400;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Tajawal', sans-serif;
            background: #0a0a0a;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }

        .background-gradient {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 20% 50%, rgba(138, 43, 226, 0.15) 0%, transparent 50%),
                        radial-gradient(circle at 80% 50%, rgba(75, 0, 130, 0.15) 0%, transparent 50%),
                        linear-gradient(135deg, #0a0a0a 0%, #1a0a2e 50%, #0a0a0a 100%);
            z-index: 0;
        }

        .particles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
            pointer-events: none;
        }

        .particle {
            position: absolute;
            width: 2px;
            height: 2px;
            background: rgba(255, 255, 255, 0.5);
            border-radius: 50%;
            animation: float 15s infinite ease-in-out;
        }

        @keyframes float {
            0%, 100% {
                transform: translate(0, 0) scale(1);
                opacity: 0;
            }
            10% {
                opacity: 1;
            }
            90% {
                opacity: 1;
            }
            100% {
                transform: translate(var(--tx), var(--ty)) scale(0);
                opacity: 0;
            }
        }

        .container {
            position: relative;
            width: 100%;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 10;
            padding: 20px;
        }

        .video-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.95);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            opacity: 1;
            transition: opacity 1.2s ease;
        }

        .video-container.fade-out {
            opacity: 0;
            pointer-events: none;
        }

        .video-wrapper {
            position: relative;
            width: 100%;
            max-width: 450px;
            aspect-ratio: 9/16;
            background: #000;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 30px 90px rgba(138, 43, 226, 0.5),
                        0 0 100px rgba(75, 0, 130, 0.3);
        }

        .video-wrapper iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: none;
        }

        .confirmation-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.95);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 2000;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.8s ease;
        }

        .confirmation-overlay.show {
            opacity: 1;
            pointer-events: all;
        }

        .confirmation-box {
            background: linear-gradient(135deg, rgba(26, 10, 46, 0.95) 0%, rgba(10, 10, 10, 0.95) 100%);
            border: 2px solid rgba(138, 43, 226, 0.5);
            border-radius: 30px;
            padding: 60px 50px;
            max-width: 500px;
            width: 90%;
            text-align: center;
            box-shadow: 0 40px 100px rgba(138, 43, 226, 0.4),
                        inset 0 0 100px rgba(138, 43, 226, 0.05);
            transform: scale(0.8);
            transition: transform 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        }

        .confirmation-overlay.show .confirmation-box {
            transform: scale(1);
        }

        .confirmation-text {
            font-size: 2.8em;
            color: #fff;
            font-weight: 700;
            margin-bottom: 40px;
            letter-spacing: 2px;
            text-shadow: 0 0 30px rgba(138, 43, 226, 0.8);
            line-height: 1.4;
        }

        .confirm-btn {
            background: linear-gradient(135deg, #8a2be2 0%, #4b0082 100%);
            color: #fff;
            border: none;
            padding: 20px 60px;
            font-size: 1.5em;
            font-weight: 700;
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 10px 40px rgba(138, 43, 226, 0.4);
            font-family: 'Tajawal', sans-serif;
            letter-spacing: 1px;
        }

        .confirm-btn:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 60px rgba(138, 43, 226, 0.6);
            background: linear-gradient(135deg, #9d4edd 0%, #5a0099 100%);
        }

        .confirm-btn:active {
            transform: translateY(-2px);
        }

        /* END SCREEN */
        .end-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #000;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 3000;
            opacity: 0;
            pointer-events: none;
            transition: opacity 1s ease;
            gap: 60px;
            padding: 30px;
        }

        .end-screen.show {
            opacity: 1;
            pointer-events: all;
        }

        .end-word {
            font-family: 'Playfair Display', serif;
            font-size: clamp(5em, 20vw, 14em);
            color: #fff;
            font-weight: 700;
            letter-spacing: 0.15em;
            text-shadow: 0 0 80px rgba(255,255,255,0.15);
            line-height: 1;
            animation: end-glow 3s ease-in-out infinite;
        }

        @keyframes end-glow {
            0%, 100% { text-shadow: 0 0 60px rgba(255,255,255,0.1); }
            50% { text-shadow: 0 0 120px rgba(255,255,255,0.25); }
        }

        .question-image {
            width: 100%;
            max-width: 380px;
            border-radius: 20px;
            box-shadow: 0 20px 80px rgba(138, 43, 226, 0.5);
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 1s ease 0.5s, transform 1s ease 0.5s;
        }

        .end-screen.show .question-image {
            opacity: 1;
            transform: translateY(0);
        }

        /* Mobile Responsive */
        @media (max-width: 768px) {
            .video-wrapper {
                max-width: 95%;
                border-radius: 15px;
            }

            .confirmation-box {
                padding: 40px 30px;
            }

            .confirmation-text {
                font-size: 2em;
            }

            .confirm-btn {
                padding: 18px 50px;
                font-size: 1.3em;
            }

            .question-image {
                max-width: 300px;
            }
        }

        @media (max-width: 480px) {
            .confirmation-text {
                font-size: 1.8em;
                margin-bottom: 30px;
            }

            .confirm-btn {
                padding: 15px 40px;
                font-size: 1.2em;
            }

            .question-image {
                max-width: 260px;
            }
        }
    </style>
</head>
<body>
    <div class="background-gradient"></div>
    <div class="particles" id="particles"></div>

    <div class="container">
        <div class="video-container" id="videoContainer">
            <div class="video-wrapper">
                <iframe 
                    allow="autoplay; fullscreen" 
                    allowfullscreen 
                    src="https://streamable.com/e/br7kq4?autoplay=1" 
                    id="videoFrame">
                </iframe>
            </div>
        </div>

        <div class="confirmation-overlay" id="confirmationOverlay">
            <div class="confirmation-box">
                <div class="confirmation-text">صافي يا لبن ؟</div>
                <button class="confirm-btn" id="confirmBtn">حليب يا اشطا</button>
            </div>
        </div>

        <div class="end-screen" id="endScreen">
            <div class="end-word">END</div>
            <img 
                class="question-image" 
                src="https://i.pinimg.com/736x/f5/84/2e/f5842eab07e9e807d5659d08cf00f360.jpg" 
                alt="question"
            />
        </div>
    </div>

    <script>
        // Create particles
        function createParticles() {
            const particlesContainer = document.getElementById('particles');
            for (let i = 0; i < 50; i++) {
                const particle = document.createElement('div');
                particle.className = 'particle';
                particle.style.left = Math.random() * 100 + '%';
                particle.style.top = Math.random() * 100 + '%';
                particle.style.setProperty('--tx', (Math.random() - 0.5) * 200 + 'px');
                particle.style.setProperty('--ty', (Math.random() - 0.5) * 200 + 'px');
                particle.style.animationDelay = Math.random() * 15 + 's';
                particle.style.animationDuration = (Math.random() * 10 + 10) + 's';
                particlesContainer.appendChild(particle);
            }
        }

        createParticles();

        let videoEnded = false;

        function showConfirmation() {
            if (videoEnded) return;
            videoEnded = true;

            const videoContainer = document.getElementById('videoContainer');
            const confirmationOverlay = document.getElementById('confirmationOverlay');
            
            videoContainer.classList.add('fade-out');
            
            setTimeout(() => {
                videoContainer.style.display = 'none';
                confirmationOverlay.classList.add('show');
            }, 1200);
        }

        function showEndScreen() {
            const confirmationOverlay = document.getElementById('confirmationOverlay');
            const endScreen = document.getElementById('endScreen');
            
            confirmationOverlay.classList.remove('show');
            
            setTimeout(() => {
                confirmationOverlay.style.display = 'none';
                endScreen.classList.add('show');
            }, 800);
        }

        // Confirm button
        document.getElementById('confirmBtn').addEventListener('click', showEndScreen);

        // Video duration (50 seconds)
        setTimeout(showConfirmation, 50000);

        // Skip video on click
        document.getElementById('videoContainer').addEventListener('click', function(e) {
            if (e.target === this || e.target.className === 'video-wrapper') {
                showConfirmation();
            }
        });
    </script>
</body>
</html>
